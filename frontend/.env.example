# 이 파일을 복사해서 '.env' 로 저장하고 실제 값을 채우세요.
#   cp .env.example .env
# .env 는 .gitignore 에 의해 커밋되지 않습니다.

# Kakao 지도/REST 키
VITE_KAKAO_JS_KEY=여기에_카카오_JS_KEY
VITE_KAKAO_REST_KEY=여기에_카카오_REST_KEY

# 백엔드 API 베이스 URL (환경별로 변경)
#   로컬:  http://localhost:8080/api/v1
#   운영:  https://api.your-domain.com/api/v1
VITE_SSAFY_API_URL=http://localhost:8080/api/v1
