/.metadata/

# ===== 민감정보 / 환경설정 (절대 커밋 금지) =====
# 백엔드 로컬/운영 설정 (실키 포함)
backend/src/main/resources/application-local.properties
backend/src/main/resources/application-prod.properties
# 단, 예시 파일은 커밋 허용
!backend/src/main/resources/*.example

# 프론트 환경변수
frontend/.env
frontend/.env.local
frontend/.env.*.local
# 예시 파일은 커밋 허용
!frontend/.env.example

# ===== 빌드 산출물 =====
backend/target/
frontend/dist/
frontend/node_modules/
node_modules/

# ===== 업로드 파일 =====
backend/uploads/
backend/target/
