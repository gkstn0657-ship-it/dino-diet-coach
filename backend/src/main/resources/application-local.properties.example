# ===== 로컬 개발 환경 설정 예시 =====
# 이 파일을 복사해서 'application-local.properties' 로 저장하고 실제 값을 채우세요.
#   cp application-local.properties.example application-local.properties
# application-local.properties 는 .gitignore 에 의해 커밋되지 않습니다.
#
# 또는 환경변수로 주입해도 됩니다 (IDE Run Configuration / 셸 export).

# --- DB ---
spring.datasource.username=ssafy
spring.datasource.password=여기에_DB_비밀번호

# --- JWT (256bit 이상 무작위 문자열로 직접 생성) ---
jwt.secret=여기에_충분히_긴_무작위_시크릿_최소32자이상

# --- GMS (SSAFY AI 게이트웨이 발급 키) ---
ai.gms.api-key=여기에_발급받은_GMS_API_KEY
spring.ai.openai.api-key=여기에_발급받은_GMS_API_KEY

# --- 식약처 식품 API (data.go.kr 발급 키) ---
food.api.key=여기에_발급받은_FOOD_API_KEY

# --- CORS (필요 시) ---
cors.allowed-origins=http://localhost:5173
